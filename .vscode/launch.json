{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Exercise API (coreclr)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/Exercise.API/bin/Debug/net9.0/Exercise.API.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Exercise.API",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            }
        },
        {
            "name": "Exercise API",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/Exercise.API/bin/Debug/net9.0/Exercise.API.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Exercise.API",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        },
        {
            "name": "Exercise API (dotnet)",
            "type": "dotnet",
            "request": "launch",
            "preLaunchTask": "build",
            "projectPath": "${workspaceFolder}/Exercise.API/Exercise.API.csproj",
            "launchSettingsProfile": "http"
        },
        {
            "name": "Expo Web",
            "type": "node-terminal",
            "request": "launch",
            "command": "npx expo start --web --port 8082",
            "cwd": "${workspaceFolder}/frontend",
            "env": {
                "EXPO_PUBLIC_API_BASE_URL": "http://localhost:5034"
            }
        },
        {
            "name": "Expo Dev Server",
            "type": "node-terminal",
            "request": "launch",
            "command": "npx expo start --port 8082",
            "cwd": "${workspaceFolder}/frontend",
            "env": {
                "EXPO_PUBLIC_API_BASE_URL": "http://localhost:5034"
            }
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ],
    "compounds": [
        {
            "name": "Full Stack: API + Expo Web",
            "configurations": [
                "Exercise API",
                "Expo Web"
            ],
            "stopAll": true
        },
        {
            "name": "Full Stack: API + Expo Dev Server",
            "configurations": [
                "Exercise API",
                "Expo Dev Server"
            ],
            "stopAll": true
        }
    ]
}
