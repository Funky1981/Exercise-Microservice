# Copy this file to .env and fill in the values before running docker-compose up
# Never commit the .env file — it is in .gitignore

# JWT signing key — must be a long, random secret (min 32 chars recommended)
JWT_KEY=your-super-secret-jwt-key-change-me

# RapidAPI key for ExerciseDB (https://rapidapi.com/justin-WFnsXH_t6/api/exercisedb)
RAPID_API_KEY=your-rapidapi-key-here
