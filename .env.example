# Copy this file to .env and fill in the values before running docker-compose up
# Never commit the .env file — it is in .gitignore
#
# ── Secrets rotation strategy ────────────────────────────────────────────────
# 1. Generate a replacement value (e.g., openssl rand -base64 32 for JWT_KEY).
# 2. Update the secret in .env (local) or your secrets manager (prod).
# 3. Restart the API container: docker compose restart api (local) or
#    kubectl rollout restart deployment/exercise-api (K8s).
# 4. Confirm /health returns 200, then revoke the old secret.
# DB_SA_PASSWORD: rotate in SQL Server with ALTER LOGIN sa WITH PASSWORD = '...'
# JWT_KEY: rotates signing — existing tokens will be invalid; users must re-login.
# RAPID_API_KEY: rotate through the RapidAPI dashboard.

# SQL Server SA password — must meet SQL Server complexity requirements (min 8 chars, mixed case + number/symbol)
DB_SA_PASSWORD=YourStrong!Passw0rd

# JWT signing key — must be a long, random secret (min 32 chars recommended)
JWT_KEY=your-super-secret-jwt-key-change-me

# RapidAPI key for ExerciseDB (https://rapidapi.com/justin-WFnsXH_t6/api/exercisedb)
RAPID_API_KEY=your-rapidapi-key-here
